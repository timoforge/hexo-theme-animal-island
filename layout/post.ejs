<% const labels = theme.labels || {}; %>
<article class="ai-article ai-paper-card">
  <header class="ai-article-header">
    <div class="ai-post-card__meta">
      <span><%- date(page.date, 'YYYY-MM-DD') %></span>
      <% if (page.categories && page.categories.length) { %>
        <span>· <%- page.categories.map(cat => cat.name).join(' / ') %></span>
      <% } %>
    </div>
    <h1><%- page.title || labels.untitled_post || '未命名文章' %></h1>
    <% if (page.tags && page.tags.length) { %>
      <div class="ai-tags">
        <% page.tags.forEach(function(tag) { %>
          <a href="<%- url_for(tag.path) %>"># <%- tag.name %></a>
        <% }); %>
      </div>
    <% } %>
  </header>
  <% if (page.photos && page.photos.length) { %>
  <div class="ai-gallery">
    <% page.photos.forEach(function(photo) { %>
      <img src="<%- url_for(photo) %>" alt="" loading="lazy">
    <% }); %>
  </div>
  <% } %>
  <div class="ai-divider"></div>
  <div class="ai-prose"><%- page.content %></div>
  <% if (page.comments !== false && config.disqus_shortname) { %>
  <section class="ai-comments">
    <div id="disqus_thread"></div>
    <script>
      var disqus_config = function () { this.page.url = '<%- page.permalink %>'; this.page.identifier = '<%- page.path %>'; };
      (function() { var d = document, s = d.createElement('script'); s.src = 'https://<%= config.disqus_shortname %>.disqus.com/embed.js'; s.setAttribute('data-timestamp', +new Date()); (d.head || d.body).appendChild(s); })();
    </script>
    <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
  </section>
  <% } %>
</article>
