<% const assets = theme.assets || {}; const hero = theme.hero || {}; const profile = theme.profile || {}; const siteTitle = config.title && config.title !== 'Hexo' ? config.title : `${profile.name || 'Islander'}的小岛`; const assetVersion = theme.asset_version || config.asset_version || (globalThis.__animalIslandAssetVersion = globalThis.__animalIslandAssetVersion || Date.now()); %>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#2abaaa">
  <meta name="description" content="<%- config.description || hero.subtitle || config.subtitle || siteTitle %>">
  <title><%- page.title ? `${page.title} | ${siteTitle}` : siteTitle %></title>
  <script>
    (() => {
      try {
        const theme = localStorage.getItem('animal-island-theme');
        document.documentElement.setAttribute('data-theme', theme === 'night' ? 'night' : 'day');
      } catch (error) {
        document.documentElement.setAttribute('data-theme', 'day');
      }
    })();
  </script>
  <link rel="stylesheet" href="<%- url_for('css/animal-island.css') %>?v=<%- assetVersion %>">
  <link rel="icon" href="<%- url_for(assets.favicon || '/images/island-assets/favicon.svg') %>" type="image/svg+xml">
  <% if (config.feed && config.feed.path) { %>
  <link rel="alternate" type="<%= config.feed.type || 'application/atom+xml' %>" title="<%= config.title %>" href="<%- url_for(config.feed.path) %>">
  <% } else { %>
  <link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%- url_for('atom.xml') %>">
  <% } %>
</head>
